generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

// ============================================================
// LEGACY TABLE (v1) - KEPT FOR BACKWARD COMPATIBILITY
// ============================================================

model mytable {
  artist      String @db.String(15)
  medium1     String @db.String(12)
  medium2     String? @db.String(12)
  price_range String @db.String(6)
  id          BigInt @id

  @@map("mytable")
}

// ============================================================
// NEW SCHEMA (v2) - MODERNIZED
// ============================================================

/// Artist entity with metadata and social links
model Artist {
  id               BigInt   @id @default(autoincrement())
  name             String   @db.String(255)
  bio              String?
  portfolioUrl     String?  @db.String(500)
  instagramHandle  String?  @db.String(100)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdBy        String?  @db.String(100)

  // Relations
  artworks         Artwork[]
  metrics          ArtistMetrics[]
  predictions      PricePrediction[]
  events           ArtistEvent[]
  interactions     Event[]

  @@unique([name])
  @@index([name])
  @@map("artists")
}

/// Artwork entity linked to artist with provenance tracking
model Artwork {
  id               BigInt   @id @default(autoincrement())
  artistId         BigInt
  medium1          String   @db.String(50)
  medium2          String?  @db.String(50)
  priceRange       String?  @db.String(20)
  sourceId         BigInt?
  externalId       String?  @db.String(255)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  artist           Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  source           GallerySource? @relation(fields: [sourceId], references: [id])

  @@index([artistId])
  @@index([sourceId])
  @@unique([externalId, sourceId])
  @@map("artworks")
}

/// Gallery source tracking (API, CSV, ICS feed, web scrape)
model GallerySource {
  id                  BigInt   @id @default(autoincrement())
  name                String   @db.String(100)
  apiEndpoint         String?  @db.String(500)
  apiKeyEncrypted     String?  @db.String(500)
  sourceType          SourceType
  lastSyncAt          DateTime?
  syncFrequencyHours  Int      @default(24)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  // Relations
  artworks            Artwork[]

  @@unique([name])
  @@index([isActive])
  @@map("gallery_sources")
}

/// Trending metrics computed on schedule (7d, 30d, 90d windows)
model ArtistMetrics {
  id                  BigInt   @id @default(autoincrement())
  artistId            BigInt
  metricWindow        MetricWindow
  viewCount           Int      @default(0)
  searchFrequency     Int      @default(0)
  marketMentions      Int      @default(0)
  trendingRank        Int?
  computedAt          DateTime @default(now())

  // Relations
  artist              Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, metricWindow])
  @@map("artist_metrics")
}

/// ML-generated value predictions across periods
model PricePrediction {
  id                  BigInt   @id @default(autoincrement())
  artistId            BigInt
  predictionPeriod    PredictionPeriod
  predictedValue      Decimal? @db.Decimal(12, 2)
  confidenceLower     Decimal? @db.Decimal(12, 2)
  confidenceUpper     Decimal? @db.Decimal(12, 2)
  modelVersion        String?  @db.String(50)
  createdAt           DateTime @default(now())

  // Relations
  artist              Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, predictionPeriod])
  @@map("price_predictions")
}

/// Artist events: exhibitions, shows, residencies
model ArtistEvent {
  id                  BigInt   @id @default(autoincrement())
  artistId            BigInt
  eventTitle          String   @db.String(255)
  eventType           EventType
  eventDate           DateTime @db.Date
  eventEndDate        DateTime? @db.Date
  venueName           String?  @db.String(255)
  venueLocation       String?  @db.String(500)
  description         String?
  sourceUrl           String?  @db.String(500)
  createdAt           DateTime @default(now())

  // Relations
  artist              Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId, eventDate])
  @@map("artist_events")
}

/// Audit log for all data mutations (compliance & debugging)
model AuditLog {
  id                  BigInt   @id @default(autoincrement())
  tableName           String   @db.String(50)
  recordId            BigInt
  action              AuditAction
  oldValues           Json?
  newValues           Json?
  changedBy           String?  @db.String(100)
  changedAt           DateTime @default(now())

  @@index([tableName, recordId])
  @@index([changedAt])
  @@map("audit_log")
}

/// User interaction tracking for trending analytics
model Event {
  id                  BigInt   @id @default(autoincrement())
  artistId            BigInt?
  eventType           InteractionType
  sessionId           String?  @db.Uuid
  timestamp           DateTime @default(now())
  metadata            Json?

  // Relations
  artist              Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)

  @@index([artistId, timestamp])
  @@map("events")
}

// ============================================================
// ENUMS
// ============================================================

enum SourceType {
  api
  csv_upload
  ics_feed
  web_scrape

  @@map("source_type_enum")
}

enum MetricWindow {
  SEVEN_DAYS    @map("7d")
  THIRTY_DAYS   @map("30d")
  NINETY_DAYS   @map("90d")

  @@map("metric_window_enum")
}

enum PredictionPeriod {
  ONE_YEAR      @map("1Y")
  THREE_YEARS   @map("3Y")
  FIVE_YEARS    @map("5Y")
  TEN_YEARS     @map("10Y")

  @@map("prediction_period_enum")
}

enum EventType {
  solo_exhibition
  group_show
  residency
  art_fair
  sale_event

  @@map("event_type_enum")
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE

  @@map("audit_action_enum")
}

enum InteractionType {
  view
  search

  @@map("interaction_type_enum")
}
