generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

// ─── LEGACY TABLE (keep until fully migrated) ────────────────────────────────
model mytable {
  id          BigInt  @id @default(sequence())
  artist      String  @db.String(15)
  medium1     String  @db.String(12)
  medium2     String? @db.String(12)
  price_range String  @db.String(6)
}

// ─── V2 SCHEMA ───────────────────────────────────────────────────────────────

model Artist {
  id               BigInt    @id @default(sequence())
  name             String
  slug             String?   @unique
  bio              String?
  website          String?
  cv_url           String?   // link to artist CV/resume page
  instagram        String?   // handle only, e.g. "@artist"
  nationality      String?
  birth_year       Int?
  active           Boolean   @default(true)

  // Career classification
  career_stage     String?   // "emerging" | "mid-career" | "established" | "late-career"

  // Show counts (from CV/Artsy)
  show_count_solo  Int       @default(0)
  show_count_group Int       @default(0)

  // Market data (from Artsy / auction records)
  artsy_url        String?   // canonical Artsy profile URL
  artsy_id         String?   // Artsy artist slug/id for API queries
  highest_sale_price    Float?   // in USD
  highest_sale_currency String? @default("USD")
  highest_sale_source   String? // "artsy" | "christies" | "sothebys" | etc.

  // Image
  profile_image_url String?  // best available image URL

  // AI enrichment fields (written by Lambda)
  bio_generated    Boolean   @default(false)
  comprehend_tags  String[]
  comprehend_ran   DateTime?

  // Enrichment tracking
  artsy_enriched_at DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  artworks         Artwork[]
  metrics          ArtistMetrics[]
  gallery_links    ArtistGallery[]

  @@map("artists")
}

model Artwork {
  id                   BigInt    @id @default(sequence())
  artist_id            BigInt
  title                String?
  year                 Int?
  medium               String?
  medium_secondary     String?
  price_range          String?
  dimensions           String?
  show_name            String?
  gallery_name         String?
  show_year            Int?

  // Cloudflare R2 image storage
  image_s3_key         String?
  image_url            String?
  thumbnail_url        String?

  // Google Cloud Vision enrichment (written by Lambda)
  rekognition_labels   Json?
  dominant_colors      Json?
  rek_ran              DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  artist               Artist    @relation(fields: [artist_id], references: [id])

  @@map("artworks")
}

model Gallery {
  id           Int      @id @default(sequence())
  name         String   @unique
  slug         String?  @unique
  city         String?
  country      String?
  website      String?
  instagram    String?
  type         String?  // "commercial" | "non-profit" | "museum" | "institution" | "art_fair"

  // Gallery tier based on career stage of artists shown
  // "mega" | "major" | "mid" | "emerging"
  gallery_tier String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artist_links ArtistGallery[]

  @@map("galleries")
}

model ArtistGallery {
  artist_id    BigInt
  gallery_id   Int
  relationship String? // "represented" | "shown" | "alumnus"
  year_start   Int?
  year_end     Int?

  artist       Artist  @relation(fields: [artist_id], references: [id])
  gallery      Gallery @relation(fields: [gallery_id], references: [id])

  @@id([artist_id, gallery_id])
  @@map("artist_galleries")
}

model ArtistMetrics {
  artistId        BigInt   @map("artist_id")
  metricWindow    String   @map("metric_window")

  // Internal engagement (kept, used until external data populates)
  searchHits      Int      @default(0) @map("search_hits")
  profileViews    Int      @default(0) @map("profile_views")
  lastViewed      DateTime? @map("last_viewed")

  viewCount       BigInt   @default(0) @map("view_count")
  searchFrequency BigInt   @default(0) @map("search_frequency")
  marketMentions  BigInt   @default(0) @map("market_mentions")

  // External metrics (replace internal metrics in scoring once populated)
  instagramFollowers    Int?    @map("instagram_followers")
  soloShowCount         Int     @default(0) @map("solo_show_count")
  groupShowCount        Int     @default(0) @map("group_show_count")
  highestSalePrice      Float?  @map("highest_sale_price")
  artsyPageViews        Int?    @map("artsy_page_views")

  trendingRank    BigInt?  @map("trending_rank")
  computedAt      DateTime @default(now()) @map("computed_at")

  artist          Artist   @relation(fields: [artistId], references: [id])

  @@id([artistId, metricWindow])
  @@map("artist_metrics")
}
