# Copy this file to .env and fill in real values. Never commit .env.
# See https://pris.ly/d/connection-strings for DATABASE_URL format.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:26257/DBNAME?sslmode=verify-full"

GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_VISION_API_KEY=your-google-vision-api-key-here

# Admin secret for /api/v2/admin/* endpoints — use a strong random string
ADMIN_SECRET_KEY=your-admin-secret-here
